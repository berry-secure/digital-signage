{
  "name": "@ds/player",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "cap:sync": "npx cap sync",
    "cap:add:android": "npx cap add android",
    "android:open": "npx cap open android",
    "android:prepare": "npm run build && npm run cap:sync",
    "android:build:debug": "npm run android:prepare && cd android && ./gradlew assembleDebug",
    "android:build:release": "npm run android:prepare && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/core": "^7.2.0",
    "pocketbase": "^0.26.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
