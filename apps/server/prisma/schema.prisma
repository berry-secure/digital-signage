generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  owner
  manager
  editor
}

enum MediaKind {
  video
  image
  audio
}

enum MediaStatus {
  draft
  published
}

enum DeviceApprovalStatus {
  pending
  approved
}

enum DeviceDisplayState {
  active
  blackout
}

enum DevicePlayerState {
  waiting
  idle
  playing
}

enum AuditAction {
  create
  update
  delete
  login
  logout
  approve_device
  reset_device
  player_session
}

model User {
  id             String          @id @default(uuid()) @db.Uuid
  email          String          @unique
  name           String
  role           UserRole        @default(editor)
  passwordHash   String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  clients        UserClient[]
  sessions       Session[]
  auditLogs      AuditLog[]
  deviceCommands DeviceCommand[]
  locationAccess UserLocationAccess[]
}

model Client {
  id         String       @id @default(uuid()) @db.Uuid
  name       String
  slug       String       @unique
  brandColor String       @default("#ff6a3c")
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  users      UserClient[]
  channels   Channel[]
  media      Media[]
  playlists  Playlist[]
  schedules  Schedule[]
  devices    Device[]
  events     PlaybackEvent[]
  locations  Location[]
}

model UserClient {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  clientId  String   @db.Uuid
  allLocations Boolean @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
  @@index([clientId])
}

model Location {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @db.Uuid
  name      String
  city      String   @default("")
  address   String   @default("")
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  channels  ChannelLocation[]
  playlistItems PlaylistItemLocation[]
  userAccess UserLocationAccess[]
  devices   Device[]

  @@index([clientId])
}

model UserLocationAccess {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  clientId  String   @db.Uuid
  locationId String  @db.Uuid
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location  Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([userId, locationId])
  @@index([clientId])
  @@index([locationId])
}

model Channel {
  id          String     @id @default(uuid()) @db.Uuid
  clientId    String     @db.Uuid
  name        String
  slug        String
  description String     @default("")
  orientation String     @default("landscape")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  client      Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  playlists   Playlist[]
  schedules   Schedule[]
  devices     Device[]
  events      PlaybackEvent[]
  locations   ChannelLocation[]

  @@unique([clientId, slug])
  @@index([clientId])
}

model ChannelLocation {
  id        String   @id @default(uuid()) @db.Uuid
  channelId String   @db.Uuid
  locationId String  @db.Uuid
  createdAt DateTime @default(now())
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  location  Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([channelId, locationId])
  @@index([locationId])
}

model Media {
  id              String         @id @default(uuid()) @db.Uuid
  clientId        String         @db.Uuid
  title           String
  kind            MediaKind
  fileName        String
  originalName    String
  mimeType        String
  durationSeconds Int            @default(10)
  hasAudio        Boolean        @default(false)
  status          MediaStatus    @default(published)
  tags            String         @default("")
  checksum        String         @default("")
  contentVersion  Int            @default(1)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  client          Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  playlistItems   PlaylistItem[]
  playbackEvents  PlaybackEvent[]

  @@index([clientId])
  @@index([status])
}

model Playlist {
  id        String         @id @default(uuid()) @db.Uuid
  clientId  String         @db.Uuid
  channelId String?        @db.Uuid
  name      String
  isActive  Boolean        @default(true)
  notes     String         @default("")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  client    Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  channel   Channel?       @relation(fields: [channelId], references: [id], onDelete: SetNull)
  items     PlaylistItem[]
  schedules Schedule[]

  @@index([clientId])
  @@index([channelId])
  @@index([isActive])
}

model PlaylistItem {
  id            String   @id @default(uuid()) @db.Uuid
  playlistId    String   @db.Uuid
  mediaId       String   @db.Uuid
  sortOrder     Int      @default(10)
  loopCount     Int      @default(1)
  volumePercent Int      @default(100)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  playlist      Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  media         Media    @relation(fields: [mediaId], references: [id], onDelete: Restrict)
  locations     PlaylistItemLocation[]

  @@index([playlistId, sortOrder])
  @@index([mediaId])
}

model PlaylistItemLocation {
  id        String   @id @default(uuid()) @db.Uuid
  playlistItemId String @db.Uuid
  locationId String  @db.Uuid
  createdAt DateTime @default(now())
  playlistItem PlaylistItem @relation(fields: [playlistItemId], references: [id], onDelete: Cascade)
  location  Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([playlistItemId, locationId])
  @@index([locationId])
}

model Schedule {
  id         String   @id @default(uuid()) @db.Uuid
  clientId   String   @db.Uuid
  channelId  String   @db.Uuid
  playlistId String   @db.Uuid
  label      String
  startDate  String   @default("")
  endDate    String   @default("")
  startTime  String   @default("00:00")
  endTime    String   @default("23:59")
  daysOfWeek String   @default("0,1,2,3,4,5,6")
  priority   Int      @default(100)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([channelId])
  @@index([playlistId])
  @@index([isActive, priority])
}

model Device {
  id                  String               @id @default(uuid()) @db.Uuid
  serial              String               @unique
  secret              String
  approvalStatus      DeviceApprovalStatus @default(pending)
  name                String               @default("Android TV")
  clientId            String?              @db.Uuid
  channelId           String?              @db.Uuid
  locationId          String?              @db.Uuid
  locationLabel       String               @default("")
  notes               String               @default("")
  platform            String               @default("android")
  appVersion          String               @default("")
  deviceModel         String               @default("Android TV")
  playerType          String               @default("video_standard")
  desiredDisplayState DeviceDisplayState   @default(active)
  volumePercent       Int                  @default(80)
  playerState         DevicePlayerState    @default(waiting)
  playerMessage       String               @default("")
  activeItemTitle     String               @default("")
  lastSeenAt          DateTime?
  lastSyncAt          DateTime?
  lastPlaybackAt      DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  client              Client?              @relation(fields: [clientId], references: [id], onDelete: SetNull)
  channel             Channel?             @relation(fields: [channelId], references: [id], onDelete: SetNull)
  location            Location?            @relation(fields: [locationId], references: [id], onDelete: SetNull)
  commands            DeviceCommand[]
  logs                DeviceLog[]
  proofOfPlay         ProofOfPlay[]

  @@index([approvalStatus])
  @@index([clientId])
  @@index([channelId])
  @@index([locationId])
  @@index([lastSeenAt])
}

model DeviceCommand {
  id                String    @id @default(uuid()) @db.Uuid
  deviceId          String    @db.Uuid
  type              String
  status            String    @default("pending")
  payload           Json?
  message           String    @default("")
  requestedByUserId String?   @db.Uuid
  requestedAt       DateTime  @default(now())
  sentAt            DateTime?
  ackedAt           DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  device            Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  requestedBy       User?     @relation(fields: [requestedByUserId], references: [id], onDelete: SetNull)

  @@index([deviceId, status])
  @@index([requestedByUserId])
  @@index([updatedAt])
}

model PlaybackEvent {
  id              String   @id @default(uuid()) @db.Uuid
  clientId        String   @db.Uuid
  channelId       String?  @db.Uuid
  mediaId         String   @db.Uuid
  name            String
  eventType       String   @default("visual")
  triggerMode     String   @default("items")
  intervalItems   Int      @default(1)
  intervalMinutes Int      @default(0)
  priority        Int      @default(100)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  channel         Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  media           Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([channelId])
  @@index([mediaId])
  @@index([isActive, priority])
}

model DeviceLog {
  id            String   @id @default(uuid()) @db.Uuid
  deviceId      String   @db.Uuid
  severity      String
  component     String
  message       String
  stack         String   @default("")
  context       Json?
  appVersion    String   @default("")
  osVersion     String   @default("")
  networkStatus String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  device        Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, createdAt])
  @@index([severity])
  @@index([component])
  @@index([createdAt])
}

model ProofOfPlay {
  id              String    @id @default(uuid()) @db.Uuid
  deviceId        String    @db.Uuid
  status          String
  sourceType      String    @default("playlist")
  playlistId      String    @default("")
  scheduleId      String    @default("")
  mediaId         String    @default("")
  playbackItemId  String    @default("")
  eventId         String    @default("")
  mediaTitle      String    @default("")
  mediaKind       MediaKind @default(video)
  startedAt       DateTime?
  finishedAt      DateTime?
  occurredAt      DateTime  @default(now())
  durationSeconds Int       @default(0)
  checksum        String    @default("")
  contentVersion  Int       @default(1)
  errorMessage    String    @default("")
  appVersion      String    @default("")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  device          Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, occurredAt])
  @@index([status])
  @@index([mediaId])
  @@index([playlistId])
  @@index([occurredAt])
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  tokenHash String   @unique
  userId    String   @db.Uuid
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id          String      @id @default(uuid()) @db.Uuid
  actorUserId String?     @db.Uuid
  action      AuditAction
  entityType  String
  entityId    String
  ipAddress   String      @default("")
  userAgent   String      @default("")
  metadata    Json?
  createdAt   DateTime    @default(now())
  actor       User?       @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
